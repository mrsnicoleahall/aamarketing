{
  "exact": {
    "/": "/",
    "/about": "/about",
    "/about-us": "/about",
    "/contact": "/contact",
    "/contact-us": "/contact",
    "/privacy-policy": "/privacy-policy",
    "/privacy": "/privacy-policy",
    "/services": "/services",
    "/intake-360": "/services/intake-360",
    "/impact-assistants": "/services/impact-assistants"
  },
  "patterns": [
    { "from": "/blog/(.*)", "to": "/blog/$1" },
    { "from": "/category/(.*)", "to": "/blog/category/$1" },
    { "from": "/tag/(.*)", "to": "/blog" },
    { "from": "/\\d{4}/\\d{2}/\\d{2}/(.*)", "to": "/blog/$1" },
    { "from": "/\\d{4}/\\d{2}/(.*)", "to": "/blog/$1" },
    { "from": "/\\d{4}/(.*)", "to": "/blog/$1" }
  ],
  "defaults": {
    "page": "/",
    "post": "/blog",
    "category": "/blog",
    "tag": "/blog",
    "archive": "/blog",
    "unknown": "/"
  }
}
