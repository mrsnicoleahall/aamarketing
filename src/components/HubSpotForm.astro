---
export interface Props {
  portalId: string;
  formId: string;
  region?: string;
}

const { portalId, formId, region = "na1" } = Astro.props;
const containerId = `hs-form-${formId.slice(0, 8)}`;
---

<div id={containerId} class="hubspot-form"></div>

<script is:inline define:vars={{ portalId, formId, region, containerId }}>
  function loadHubSpotForm() {
    if (window.hbspt) {
      window.hbspt.forms.create({
        portalId,
        formId,
        region,
        target: `#${containerId}`,
      });
    } else {
      const script = document.createElement("script");
      script.src = "//js.hsforms.net/forms/embed/v2.js";
      script.charset = "utf-8";
      script.onload = function () {
        window.hbspt.forms.create({
          portalId,
          formId,
          region,
          target: `#${containerId}`,
        });
      };
      document.head.appendChild(script);
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", loadHubSpotForm);
  } else {
    loadHubSpotForm();
  }
</script>

<style>
  .hubspot-form :global(.hs-form) {
    font-family: inherit;
  }
  .hubspot-form :global(.hs-form fieldset) {
    max-width: 100%;
  }
  .hubspot-form :global(.hs-form label) {
    color: #ffffff;
    font-weight: 600;
    font-size: 0.875rem;
    margin-bottom: 0.25rem;
    display: block;
  }
  .hubspot-form :global(.hs-form .hs-error-msg) {
    color: #7f1d1d;
  }
  .hubspot-form :global(.hs-form .hs-input) {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border: 1px solid #d1d5db;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    background-color: #ffffff;
    color: #0b0000;
  }
  .hubspot-form :global(.hs-form select.hs-input) {
    appearance: auto;
  }
  .hubspot-form :global(.hs-form .hs-button) {
    background-color: #50a7dd;
    color: #ffffff;
    font-weight: 600;
    padding: 0.75rem 2rem;
    border-radius: 0.375rem;
    border: none;
    cursor: pointer;
    font-size: 1rem;
    transition: background-color 0.2s;
  }
  .hubspot-form :global(.hs-form .hs-button:hover) {
    background-color: #3b8abf;
  }
  .hubspot-form :global(.hs-form .hs-richtext) {
    color: #ffffff;
    font-size: 0.75rem;
  }
  .hubspot-form :global(.hs-form .hs-fieldtype-text),
  .hubspot-form :global(.hs-form .hs-fieldtype-phonenumber),
  .hubspot-form :global(.hs-form .hs-fieldtype-select) {
    margin-bottom: 0.5rem;
  }
</style>
