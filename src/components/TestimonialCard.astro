---
export interface Props {
  clientName: string;
  company?: string;
  role?: string;
  testimonialQuote: string;
  headshot?: string | null;
  rating?: number;
}

const { clientName, company, role, testimonialQuote, headshot, rating } = Astro.props;
---

<div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
  {rating && (
    <div class="flex gap-1 mb-3">
      {Array.from({ length: 5 }).map((_, i) => (
        <svg
          class:list={["w-5 h-5", i < rating ? "text-brand-gold" : "text-gray-200"]}
          fill="currentColor"
          viewBox="0 0 20 20"
        >
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
      ))}
    </div>
  )}

  <blockquote class="text-gray-700 text-base leading-relaxed mb-4">
    &ldquo;{testimonialQuote}&rdquo;
  </blockquote>

  <div class="flex items-center gap-3">
    {headshot && (
      <img
        src={headshot}
        alt={clientName}
        class="w-10 h-10 rounded-full object-cover"
        loading="lazy"
      />
    )}
    <div>
      <p class="font-heading font-semibold text-sm text-brand-black">{clientName}</p>
      {(role || company) && (
        <p class="text-xs text-gray-500">
          {role}{role && company && ", "}{company}
        </p>
      )}
    </div>
  </div>
</div>
