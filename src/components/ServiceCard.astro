---
export interface Props {
  title: string;
  description: string;
  icon?: string;
  link?: string;
}

const { title, description, icon, link } = Astro.props;
const Tag = link ? "a" : "div";
const hasSlot = Astro.slots.has("icon");
---

<Tag
  href={link}
  class:list={[
    "block bg-white rounded-xl p-6 shadow-sm border border-gray-100 transition-all duration-200",
    link && "hover:shadow-md hover:-translate-y-1 hover:border-brand-blue/30",
  ]}
>
  <div class="w-14 h-14 rounded-lg bg-brand-navy/10 flex items-center justify-center mb-4">
    {hasSlot ? (
      <slot name="icon" />
    ) : icon ? (
      <img src={icon} alt="" class="w-8 h-8" loading="lazy" />
    ) : null}
  </div>
  <h3 class="text-lg font-heading font-bold text-brand-black mb-2">{title}</h3>
  <p class="text-gray-600 text-sm leading-relaxed">{description}</p>
</Tag>
