---
export interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  backgroundImage?: string;
  overlay?: boolean;
}

const { title, subtitle, ctaText, ctaLink, backgroundImage, overlay = true } = Astro.props;
---

<section class="relative py-20 lg:py-32 text-white">
  <div class="absolute inset-0">
    <img src={backgroundImage || "/brand/hero-bg.png"} alt="" class="w-full h-full object-cover" />
    {overlay && <div class="absolute inset-0 bg-black/60" />}
  </div>

  <div class="container-wide relative z-10">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-6">
        {title}
      </h1>
      {subtitle && (
        <p class="text-lg md:text-xl text-white/80 mb-8 leading-relaxed">
          {subtitle}
        </p>
      )}
      {ctaText && ctaLink && (
        <a href={ctaLink} class="btn-primary text-base">
          {ctaText}
        </a>
      )}
    </div>
  </div>
</section>
