---
import BaseLayout from "@layouts/BaseLayout.astro";
import BlogCard from "@components/BlogCard.astro";
import { fetchAllBlogPosts, fetchBlogTags } from "@lib/hubspot";

export async function getStaticPaths() {
  let tags: any[] = [];
  try {
    tags = await fetchBlogTags();
  } catch {}
  return tags.map((tag) => ({ params: { slug: tag.slug } }));
}

const { slug } = Astro.params;
let allPosts: any[] = [];
let tags: any[] = [];

try {
  allPosts = (await fetchAllBlogPosts()) || [];
  tags = (await fetchBlogTags()) || [];
} catch {}

const currentTag = tags.find((t: any) => t.slug === slug);
const posts = allPosts.filter((post: any) =>
  post.tags.some((t: any) => t.slug === slug)
);
---

<BaseLayout
  title={currentTag ? `${currentTag.name} — Blog` : "Category — Blog"}
  description={`Browse articles in the ${currentTag?.name || ""} category.`}
>

  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <div class="mb-12">
        <a href="/blog" class="text-brand-blue text-sm font-medium hover:underline mb-2 inline-block">&larr; All Posts</a>
        <h1 class="text-4xl font-heading font-bold mb-4">{currentTag?.name || "Category"}</h1>
      </div>

      {tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          <a href="/blog" class="text-sm font-medium px-3 py-1.5 rounded-full bg-gray-100 text-gray-700 hover:bg-brand-blue hover:text-white transition-colors">All</a>
          {tags.map((tag: any) => (
            <a
              href={`/blog/category/${tag.slug}`}
              class:list={[
                "text-sm font-medium px-3 py-1.5 rounded-full transition-colors",
                tag.slug === slug
                  ? "bg-gray-900 text-white"
                  : "bg-gray-100 text-gray-700 hover:bg-brand-blue hover:text-white",
              ]}
            >
              {tag.name}
            </a>
          ))}
        </div>
      )}

      {posts.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {posts.map((post: any) => (
            <BlogCard
              title={post.title}
              slug={post.slug}
              excerpt={post.excerpt}
              featuredImage={post.featuredImage}
              publishedDate={post.publishedDate}
              author={{ name: post.authorName }}
              tags={post.tags}
            />
          ))}
        </div>
      ) : (
        <p class="text-gray-500 text-lg text-center py-16">No posts in this category yet.</p>
      )}
    </div>
  </section>

</BaseLayout>
