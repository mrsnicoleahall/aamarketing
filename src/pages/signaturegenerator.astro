            const email = document.getElementById('email').value || 'email@attorneyassistant.com';

            const logoUrl = useAbsoluteUrls ? LOGO_ABSOLUTE : LOGO_LOCAL;

            const signature = `<div style="font-family:Aptos,Aptos_EmbeddedFont,Aptos_MSFontService,Calibri,Helvetica,sans-serif; font-size:12pt; color:rgb(0,0,0)">
