                                                                <div style="direction:ltr; text-align:left; line-height:11.88px; white-space:nowrap; margin:1px; font-family:Aptos,Aptos_EmbeddedFont,Aptos_MSFontService,Calibri,Helvetica,sans-serif; font-size:9pt">
                                                                    <span style="color:rgb(11,0,0)"><b>Website</b> </span><span style="color:rgb(80,167,221)"><a style="color:rgb(80,167,221)" rel="noopener noreferrer" target="_blank" href="https://attorneyassistant.com">attorneyassistant.com</a></span>
