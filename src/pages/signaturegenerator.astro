                                                                    <span style="color:rgb(11,0,0)"><b>Phone</b> ${phone} | <b>Email</b> </span><span style="color:rgb(33,33,33)"><a style="color:rgb(33,33,33)" href="mailto:${email}">${email}</a></span>
