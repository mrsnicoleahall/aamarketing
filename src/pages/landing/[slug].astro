---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import FeatureCard from "@components/FeatureCard.astro";
import TestimonialCard from "@components/TestimonialCard.astro";
import CTABanner from "@components/CTABanner.astro";
import { fetchLandingPageSlugs, fetchLandingPageBySlug } from "@lib/hubspot";

export async function getStaticPaths() {
  let slugs: { slug: string }[] = [];
  try {
    slugs = await fetchLandingPageSlugs();
  } catch {}
  return slugs.map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const page = await fetchLandingPageBySlug(slug!);

if (!page) {
  return Astro.redirect("/");
}
---

<BaseLayout
  title={page.seo_title || page.hero_title || page.title}
  description={page.seo_description}
  image={page.hero_image}
>

  <Hero
    title={page.hero_title}
    subtitle={page.hero_subtitle}
    ctaText={page.cta_text}
    ctaLink={page.cta_link}
    backgroundImage={page.hero_image}
  />

  {page.sections?.map((section: any) => {
    if (section.type === "hero") {
      return (
        <Hero
          title={section.heading}
          subtitle={section.subheading}
          ctaText={section.cta_text}
          ctaLink={section.cta_link}
        />
      );
    }

    if (section.type === "cta") {
      return (
        <CTABanner
          heading={section.heading}
          body={section.body}
          buttonText={section.button_text}
          buttonLink={section.button_link}
          variant={section.style || "default"}
        />
      );
    }

    if (section.type === "feature_grid") {
      return (
        <section class="py-16 lg:py-24 bg-gray-50">
          <div class="container-wide">
            {section.heading && <h2 class="text-3xl font-heading font-bold text-center mb-12">{section.heading}</h2>}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
              {section.features?.map((f: any) => (
                <FeatureCard title={f.title} description={f.description} icon={f.icon} />
              ))}
            </div>
          </div>
        </section>
      );
    }

    if (section.type === "text_with_image") {
      return (
        <section class="py-16 lg:py-24">
          <div class="container-wide">
            <div class:list={["grid md:grid-cols-2 gap-12 items-center", section.image_position === "left" && "md:flex-row-reverse"]}>
              <div class:list={[section.image_position === "left" && "md:order-2"]}>
                {section.heading && <h2 class="text-3xl font-heading font-bold mb-6">{section.heading}</h2>}
                {section.body && <div class="prose" set:html={section.body} />}
              </div>
              {section.image && (
                <div class:list={[section.image_position === "left" && "md:order-1"]}>
                  <img src={section.image} alt={section.image_alt || ""} class="rounded-xl w-full" loading="lazy" />
                </div>
              )}
            </div>
          </div>
        </section>
      );
    }

    if (section.type === "testimonials") {
      return (
        <section class="py-16 lg:py-24 bg-gray-50">
          <div class="container-wide">
            {section.heading && <h2 class="text-3xl font-heading font-bold text-center mb-12">{section.heading}</h2>}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
              {section.testimonials?.map((t: any) => <TestimonialCard {...t} />)}
            </div>
          </div>
        </section>
      );
    }

    if (section.type === "faq") {
      return (
        <section class="py-16 lg:py-24">
          <div class="container-narrow">
            {section.heading && <h2 class="text-3xl font-heading font-bold text-center mb-12">{section.heading}</h2>}
            <div class="space-y-4">
              {section.faqs?.map((faq: any) => (
                <details class="group bg-white rounded-lg border border-gray-200 p-4">
                  <summary class="flex items-center justify-between cursor-pointer font-heading font-semibold">
                    {faq.question}
                    <svg class="w-5 h-5 text-gray-500 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <p class="mt-3 text-gray-600">{faq.answer}</p>
                </details>
              ))}
            </div>
          </div>
        </section>
      );
    }

    return null;
  })}

  {page.cta_text && page.cta_link && (
    <CTABanner
      heading="Ready to Get Started?"
      buttonText={page.cta_text}
      buttonLink={page.cta_link}
    />
  )}

</BaseLayout>
