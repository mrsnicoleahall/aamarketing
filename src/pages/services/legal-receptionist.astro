---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import FeatureCard from "@components/FeatureCard.astro";
import CTABanner from "@components/CTABanner.astro";
---

<BaseLayout title="Legal Receptionist" description="A virtual receptionist for your law firm — freeing up your team to focus on high-priority tasks instead of answering calls.">

  <Hero
    title="Legal Receptionist"
    subtitle="A virtual receptionist for your law firm — freeing up your team to focus on high-priority tasks instead of answering calls."
    ctaText="Get Started"
    ctaLink="/contact"
  />

  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">Professional Front-Desk <em class="not-italic text-brand-gold italic">Support</em></h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Every call answered, every appointment booked, every detail captured — without the overhead of a full-time hire.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <FeatureCard title="Answering Calls" description="Every caller greeted with care and professionalism. Clients and leads routed appropriately with important details captured accurately." icon="users" />
        <FeatureCard title="Scheduling Appointments" description="Consultations, case updates, and internal meetings — bookings, reminders, and rescheduling handled seamlessly." icon="clock" />
        <FeatureCard title="Administrative Tasks" description="Intake, call logging, CRM updates, and other admin tasks to keep front-desk operations running smoothly." icon="document" />
        <FeatureCard title="Call Screening & Routing" description="Qualified calls routed to the right attorney. Non-urgent matters handled efficiently without interrupting your workflow." icon="shield" />
        <FeatureCard title="Message Management" description="Detailed messages delivered promptly via your preferred channel — email, CRM notes, or chat." icon="chart" />
        <FeatureCard title="Bilingual Support" description="English and Spanish-speaking receptionists serve your diverse client base without language barriers." icon="scale" />
      </div>
    </div>
  </section>

  <CTABanner
    heading="Add a Virtual Receptionist"
    body="Receptionist coverage pairs seamlessly with our other services. We'll build a custom combination — legal assistants, admin support, marketing — so your firm is covered end to end."
    buttonText="Schedule Consultation"
    buttonLink="/contact"
    variant="gold"
  />

</BaseLayout>
