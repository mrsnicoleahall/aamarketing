---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import FeatureCard from "@components/FeatureCard.astro";
import CTABanner from "@components/CTABanner.astro";
import TestimonialCard from "@components/TestimonialCard.astro";
import { fetchFeaturedTestimonials } from "@lib/hubspot";

let testimonials: any[] = [];
try {
  testimonials = (await fetchFeaturedTestimonials()) || [];
} catch {}
---

<BaseLayout title="Intake 360" description="Comprehensive 24/7 client intake services for law firms. Capture every lead, qualify prospects, and set cases up for success.">

  <Hero
    title="Intake 360"
    subtitle="Never miss another lead. Our comprehensive intake service captures every call, qualifies every prospect, and feeds your pipeline 24/7."
    ctaText="Get Started"
    ctaLink="/contact"
  />

  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">Complete Intake Coverage</h2>
        <p class="text-gray-600 max-w-2xl mx-auto">Every touchpoint is an opportunity. Intake 360 ensures you capture them all.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <FeatureCard title="24/7 Live Answering" description="Trained intake specialists answer every call, day or night, weekends and holidays included." icon="clock" />
        <FeatureCard title="Lead Qualification" description="Custom qualification criteria ensure only viable leads reach your attorneys, saving valuable time." icon="shield" />
        <FeatureCard title="Bilingual Support" description="English and Spanish-speaking specialists serve your diverse client base without language barriers." icon="users" />
        <FeatureCard title="CRM Integration" description="Seamless integration with your existing case management and CRM systems for zero-friction handoff." icon="document" />
        <FeatureCard title="Custom Scripts" description="Intake scripts tailored to your practice areas, ensuring consistent and thorough information capture." icon="document" />
        <FeatureCard title="Real-Time Reporting" description="Live dashboards and detailed reports give you complete visibility into your intake pipeline." icon="chart" />
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-center mb-12">How It Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {[
          { step: "1", title: "We Answer", desc: "Calls are answered by trained specialists using your custom scripts and branding." },
          { step: "2", title: "We Qualify", desc: "Each prospect is evaluated against your criteria and detailed information is captured." },
          { step: "3", title: "You Connect", desc: "Qualified leads are delivered to your team in real time via your preferred channel." },
        ].map((item) => (
          <div class="text-center">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-brand-gold text-brand-black font-heading font-bold text-xl mb-4">
              {item.step}
            </div>
            <h3 class="font-heading font-semibold text-xl mb-2">{item.title}</h3>
            <p class="text-gray-600">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {testimonials.length > 0 && (
    <section class="py-16 lg:py-24">
      <div class="container-wide">
        <h2 class="text-3xl font-heading font-bold text-center mb-12">Client Results</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {testimonials.slice(0, 3).map((t: any) => <TestimonialCard {...t} />)}
        </div>
      </div>
    </section>
  )}

  <section class="py-12 lg:py-16 bg-gray-50">
    <div class="container-narrow text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-bold text-brand-black mb-4">
        <em class="not-italic text-brand-gold italic">Complete</em> Coverage for Your <em class="not-italic text-brand-blue italic">Firm</em>
      </h2>
      <p class="text-gray-600 text-lg leading-relaxed max-w-2xl mx-auto">
        Intake 360 captures every lead — and pairing it with a dedicated <a href="/services/impact-assistants" class="text-brand-blue underline hover:text-brand-navy">Impact Assistant</a> gives your firm comprehensive coverage from first call to case resolution. Most of our clients benefit from this strategic combination, and our team will help you find the right mix.
      </p>
      <a href="/contact" class="btn-primary mt-6 inline-block">Build Your Custom Solution</a>
    </div>
  </section>

  <CTABanner
    heading="Start Capturing Every Lead"
    body="Join the firms that have transformed their intake process with Intake 360."
    buttonText="Schedule a Demo"
    buttonLink="/contact"
  />

</BaseLayout>
