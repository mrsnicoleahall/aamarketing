---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import FeatureCard from "@components/FeatureCard.astro";
import CTABanner from "@components/CTABanner.astro";
---

<BaseLayout title="Marketing Support" description="Dedicated marketing support specialists to help law firms execute their marketing strategies efficiently and professionally.">

  <Hero
    title="Marketing Support"
    subtitle="Dedicated marketing support specialists to help law firms execute their marketing strategies efficiently and professionally."
    ctaText="Get Started"
    ctaLink="/contact"
  />

  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">Marketing Execution, <em class="not-italic text-brand-gold italic">Handled</em></h2>
        <p class="text-gray-600 max-w-2xl mx-auto">From content scheduling to reputation management, your marketing specialist keeps campaigns running smoothly.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <FeatureCard title="Content Posting & Scheduling" description="Upload and schedule social media posts, newsletters, and blogs. Keep your marketing calendar on track with consistent, timely distribution." icon="document" />
        <FeatureCard title="Email Campaign Coordination" description="Schedule and manage email campaigns, monitor open and click-through rates, and report results." icon="chart" />
        <FeatureCard title="CRM Management & Lead Tracking" description="Log campaign performance data, tag leads, and track engagement to keep your pipeline organized." icon="users" />
        <FeatureCard title="Event & Webinar Coordination" description="Handle logistics, scheduling, and promotion for webinars or in-person events." icon="clock" />
        <FeatureCard title="Website & Graphic Updates" description="Minor updates to pre-approved website content and templated graphics, maintaining professional brand presence." icon="shield" />
        <FeatureCard title="Reputation & Review Management" description="Request client reviews, monitor brand mentions, and flag feedback to protect your firm's reputation." icon="scale" />
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="container-narrow">
      <h2 class="text-3xl font-heading font-bold text-center mb-12">Additional Capabilities</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {[
          { title: "Performance Monitoring & Reporting", desc: "Track KPIs and compile summary reports to refine strategy and increase ROI." },
          { title: "Competitor & Trend Monitoring", desc: "Gather and log competitor examples or industry trends." },
        ].map((item) => (
          <div class="flex items-start gap-3 p-4 bg-white rounded-lg">
            <svg class="w-6 h-6 text-brand-gold flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
            </svg>
            <div>
              <span class="font-heading font-semibold text-gray-900">{item.title}</span>
              <p class="text-gray-600 text-sm mt-1">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Scale Your Firm's Marketing"
    body="Marketing support fits right into a broader service package. We'll combine it with legal assistants, admin, or receptionist coverage to build the right team for your firm."
    buttonText="Schedule Consultation"
    buttonLink="/contact"
    variant="gold"
  />

</BaseLayout>
