---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import FeatureCard from "@components/FeatureCard.astro";
import CTABanner from "@components/CTABanner.astro";
---

<BaseLayout title="Admin Support" description="Virtual legal administrative support to handle time-consuming, repetitive tasks — so your team can focus on managing the firm.">

  <Hero
    title="Admin Support"
    subtitle="Virtual legal administrative support to handle time-consuming, repetitive tasks — so your team can focus on managing the firm."
    ctaText="Get Started"
    ctaLink="/contact"
  />

  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-heading font-bold mb-4">What Our Admin Assistants <em class="not-italic text-brand-gold italic">Handle</em></h2>
        <p class="text-gray-600 max-w-2xl mx-auto">From phones to filing, we take on the repetitive tasks that slow your team down.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <FeatureCard title="Answering Phones" description="Every call answered promptly and professionally. Every caller feels heard and is routed correctly." icon="users" />
        <FeatureCard title="Scheduling Meetings" description="Coordinate internal meetings, client calls, and court dates to keep schedules aligned and conflict-free." icon="clock" />
        <FeatureCard title="Filing" description="Maintain organized filing systems — motions, memos, everything labeled, stored, and easy to find." icon="document" />
        <FeatureCard title="Document Collection" description="Track down signed fee agreements, request medical records, handle follow-ups so nothing falls through the cracks." icon="shield" />
        <FeatureCard title="CRM Management" description="Case updates, client documents, and correspondence uploaded into your CRM accurately and efficiently." icon="chart" />
        <FeatureCard title="Repetitive Task Handling" description="Data entry, email processing, form submissions — we handle the daily busywork so attorneys stay focused." icon="scale" />
      </div>
    </div>
  </section>

  <CTABanner
    heading="Get Admin Support Today"
    body="Admin support works best as part of a custom service package. We'll combine it with legal assistant, receptionist, or marketing coverage to match your firm's exact needs."
    buttonText="Schedule Consultation"
    buttonLink="/contact"
  />

</BaseLayout>
