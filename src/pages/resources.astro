---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";

const resources = [
  {
    title: "Scripts",
    description: "Ready-to-use intake and follow-up scripts tailored for law firms. Download and customize for your practice areas.",
    href: "/all-scripts-2025",
    icon: "document",
  },
  {
    title: "Guides",
    description: "In-depth guides on legal operations, intake optimization, and building a more efficient law firm.",
    href: "/guides",
    icon: "book",
  },
  {
    title: "Podcasts",
    description: "Listen to expert conversations on legal industry trends, firm growth strategies, and operational best practices.",
    href: "/podcast",
    icon: "headphones",
  },
  {
    title: "Webinars",
    description: "On-demand webinars covering everything from intake best practices to scaling your firm with virtual support.",
    href: "/webinars",
    icon: "video",
  },
  {
    title: "Blog",
    description: "Insights, tips, and best practices from the Attorney Assistant team to help your firm thrive.",
    href: "/blog",
    icon: "pencil",
  },
];
---

<BaseLayout title="Resources" description="Free resources to help empower law firms to operate smarter. Scripts, guides, podcasts, webinars, and more.">

  <Hero
    title="Resources"
    subtitle="Free resources to help empower law firms to operate smarter."
  />

  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {resources.map((resource) => (
          <a href={resource.href} class="group block bg-white rounded-xl p-8 shadow-sm border border-gray-100 hover:shadow-md hover:border-brand-gold/30 transition-all duration-200">
            <div class="w-14 h-14 rounded-xl bg-brand-gold/10 flex items-center justify-center mb-6">
              {resource.icon === "document" && (
                <svg class="w-7 h-7 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
              )}
              {resource.icon === "book" && (
                <svg class="w-7 h-7 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" /></svg>
              )}
              {resource.icon === "headphones" && (
                <svg class="w-7 h-7 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" /></svg>
              )}
              {resource.icon === "video" && (
                <svg class="w-7 h-7 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m15.75 10.5 4.72-4.72a.75.75 0 0 1 1.28.53v11.38a.75.75 0 0 1-1.28.53l-4.72-4.72M4.5 18.75h9a2.25 2.25 0 0 0 2.25-2.25v-9a2.25 2.25 0 0 0-2.25-2.25h-9A2.25 2.25 0 0 0 2.25 7.5v9a2.25 2.25 0 0 0 2.25 2.25z" /></svg>
              )}
              {resource.icon === "pencil" && (
                <svg class="w-7 h-7 text-brand-gold" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /></svg>
              )}
            </div>
            <h3 class="text-xl font-heading font-bold text-brand-black mb-3 group-hover:text-brand-gold transition-colors">{resource.title}</h3>
            <p class="text-gray-600 leading-relaxed">{resource.description}</p>
            <span class="inline-flex items-center mt-4 text-brand-blue font-heading font-semibold text-sm group-hover:gap-2 transition-all">
              Explore {resource.title}
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="newsletter" class="py-16 lg:py-24 bg-gray-50">
    <div class="container-narrow text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-black mb-4">Subscribe For The Latest Resources</h2>
      <p class="text-gray-600 text-lg mb-8 max-w-2xl mx-auto">Stay up to date with the latest scripts, guides, and insights for running a more efficient law firm.</p>
      <a href="/contact" class="btn-primary text-base">Get in Touch &rarr;</a>
    </div>
  </section>

  <CTABanner
    heading="Ready to Transform Your Practice?"
    body="Get in touch to learn how Attorney Assistant can streamline your legal operations."
    buttonText="Get Started"
    buttonLink="/contact"
  />

</BaseLayout>
