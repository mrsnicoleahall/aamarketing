---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import CTABanner from "@components/CTABanner.astro";
import YouTubeEmbed from "@components/YouTubeEmbed.astro";

const latestEpisodes = [
  {
    title: "How Family Lawyer Deidra Haynes Grew Her Law Firm Fast",
    duration: "17 min",
    date: "Jun 16, 2025",
    videoId: "MHvos0nNwqw",
    season: "S1 EP5",
  },
  {
    title: "From Frustration To Law Firm Founder - Meet Alan Kaplan!",
    duration: "33 min",
    date: "May 21, 2025",
    videoId: "pul5DW0gqGA",
    season: "S1 EP4",
  },
  {
    title: "Mastering Legal Success with Ethen & Bob",
    duration: "26 min",
    date: "Apr 24, 2025",
    videoId: "cUEPjMTfNKQ",
    season: "S1 EP3",
  },
];

const popularEpisodes = [
  {
    title: "Inside Mass Torts & Class Actions with Joe & Ethen",
    duration: "38 min",
    videoId: "VxaICb6wj4o",
    season: "S1 EP2",
  },
  {
    title: "Mastering Business Growth with Ethen & James",
    duration: "22 min",
    videoId: "oAMwKyji1KA",
    season: "S1 EP1",
  },
];

const platforms = [
  {
    name: "Apple Podcasts",
    url: "https://podcasts.apple.com/us/podcast/the-growth-code-podcast/id1801516380",
    icon: "apple",
  },
  {
    name: "Spotify",
    url: "https://open.spotify.com/show/7ob6WOvt2NlqQOpoyUit4m?si=ca0d7daaa12a4b8b",
    icon: "spotify",
  },
  {
    name: "Podbean",
    url: "https://growthcodepodcast.podbean.com/",
    icon: "podbean",
  },
];
---

<BaseLayout title="The Growth Code Podcast" description="Discover the art of scaling smarter, not harder. Tech, automation, and strategies for entrepreneurs, law firm owners, and business leaders.">

  <Hero
    title="The Growth Code Podcast"
    subtitle="Discover the art of scaling smarter, not harder. Tech, automation, and strategies for entrepreneurs, law firm owners, and business leaders."
  />

  <!-- Latest Episodes -->
  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-black mb-12">Latest Episodes</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {latestEpisodes.map((episode) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-brand-gold/30 transition-all duration-200 overflow-hidden">
            <YouTubeEmbed videoId={episode.videoId} title={episode.title} />
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-heading font-semibold text-brand-blue bg-brand-blue/10 px-2 py-1 rounded-full">
                  {episode.season}
                </span>
                <span class="text-xs text-gray-500">{episode.duration}</span>
                <span class="text-xs text-gray-400">{episode.date}</span>
              </div>
              <h3 class="font-heading font-bold text-lg text-brand-black leading-snug">
                {episode.title}
              </h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Popular Episodes -->
  <section class="py-16 lg:py-24 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-black mb-12">Popular Episodes</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl">
        {popularEpisodes.map((episode) => (
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-brand-gold/30 transition-all duration-200 overflow-hidden">
            <YouTubeEmbed videoId={episode.videoId} title={episode.title} />
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-xs font-heading font-semibold text-brand-blue bg-brand-blue/10 px-2 py-1 rounded-full">
                  {episode.season}
                </span>
                <span class="text-xs text-gray-500">{episode.duration}</span>
              </div>
              <h3 class="font-heading font-bold text-lg text-brand-black leading-snug">
                {episode.title}
              </h3>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Never Miss an Episode -->
  <section class="py-16 lg:py-24">
    <div class="container-wide text-center">
      <h2 class="text-3xl md:text-4xl font-heading font-bold text-brand-black mb-4">Never Miss an Episode</h2>
      <p class="text-gray-600 text-lg mb-12 max-w-2xl mx-auto">Subscribe on your favorite platform and stay up to date with the latest episodes.</p>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
        {platforms.map((platform) => (
          <a
            href={platform.url}
            target="_blank"
            rel="noopener"
            class="group flex flex-col items-center gap-4 bg-white rounded-xl p-8 shadow-sm border border-gray-100 hover:shadow-md hover:border-brand-gold/30 transition-all duration-200"
          >
            {platform.icon === "apple" && (
              <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 flex items-center justify-center">
                <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
                </svg>
              </div>
            )}
            {platform.icon === "spotify" && (
              <div class="w-14 h-14 rounded-xl bg-[#1DB954] flex items-center justify-center">
                <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z" />
                </svg>
              </div>
            )}
            {platform.icon === "podbean" && (
              <div class="w-14 h-14 rounded-xl bg-[#6CBD45] flex items-center justify-center">
                <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 18.75a6 6 0 006-6v-1.5m-6 7.5a6 6 0 01-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15.75a3 3 0 01-3-3V4.5a3 3 0 116 0v8.25a3 3 0 01-3 3z" />
                </svg>
              </div>
            )}
            <span class="font-heading font-semibold text-brand-black group-hover:text-brand-gold transition-colors">
              {platform.name}
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABanner
    heading="Ready to Transform Your Practice?"
    body="Get in touch to learn how Attorney Assistant can streamline your legal operations."
    buttonText="Get Started"
    buttonLink="/contact"
  />

</BaseLayout>
