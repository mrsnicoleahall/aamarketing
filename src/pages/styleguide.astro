---
import BaseLayout from "@layouts/BaseLayout.astro";

const colors = [
  { name: "Brand Gold", value: "#ffaa2b", css: "brand-gold", usage: "Primary CTA buttons, accents, highlights" },
  { name: "Brand Blue", value: "#50a7dd", css: "brand-blue", usage: "Links, secondary buttons, active states" },
  { name: "Brand Black", value: "#0b0000", css: "brand-black", usage: "Body text, headings (not footer)" },
  { name: "Footer Gray", value: "#111827", css: "gray-900", usage: "Footer background" },
  { name: "Brand Navy", value: "#1a3a5c", css: "brand-navy", usage: "Hero overlays, dark backgrounds" },
  { name: "Brand Steel", value: "#588aa5", css: "brand-steel", usage: "Subtle accents, secondary text" },
  { name: "Brand White", value: "#ffffff", css: "brand-white", usage: "Backgrounds, reversed text" },
];

const logos = [
  { file: "Attorney%20Assistant_H_FC.svg", label: "Horizontal — Full Color", bg: "bg-white", darkBg: false },
  { file: "Attorney%20Assistant_H_Black.svg", label: "Horizontal — Black", bg: "bg-white", darkBg: false },
  { file: "Attorney%20Assistant_H_White.svg", label: "Horizontal — White", bg: "bg-brand-navy", darkBg: true },
  { file: "Attorney%20Assistant_V_FC.svg", label: "Vertical — Full Color", bg: "bg-white", darkBg: false },
  { file: "Attorney%20Assistant_V_Black.svg", label: "Vertical — Black", bg: "bg-white", darkBg: false },
  { file: "Attorney%20Assistant_V_White.svg", label: "Vertical — White", bg: "bg-brand-navy", darkBg: true },
  { file: "color_icon.svg", label: "Icon — Color (Favicon)", bg: "bg-white", darkBg: false },
  { file: "color_icon.png", label: "Icon — Color PNG", bg: "bg-white", darkBg: false },
];
---

<BaseLayout title="Style Guide" description="Attorney Assistant brand style guide — logos, colors, typography, and marketing assets.">

  <!-- Header -->
  <section class="py-16 lg:py-20 bg-gray-900 text-white">
    <div class="container-wide">
      <p class="text-brand-gold font-heading font-semibold text-sm uppercase tracking-wider mb-4">Internal Reference</p>
      <h1 class="text-4xl md:text-5xl font-heading font-bold mb-4">Style Guide</h1>
      <p class="text-white/70 text-lg max-w-2xl">Brand assets, colors, typography, and usage guidelines for creating consistent marketing materials.</p>
    </div>
  </section>

  <!-- Logos -->
  <section class="py-16 lg:py-20">
    <div class="container-wide">
      <h2 class="text-3xl font-heading font-bold text-brand-black mb-2">Logos</h2>
      <p class="text-gray-600 mb-8">Download and use the appropriate logo variant for your context. Always maintain clear space around the logo.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {logos.map((logo) => (
          <div class="border border-gray-200 rounded-xl overflow-hidden">
            <div class:list={[logo.bg, "p-8 flex items-center justify-center min-h-[140px]"]}>
              <img src={`/brand/logos/${logo.file}`} alt={logo.label} class="max-h-20 max-w-full" />
            </div>
            <div class="p-4 border-t border-gray-200 flex items-center justify-between">
              <span class="text-sm text-gray-600">{logo.label}</span>
              <a
                href={`/brand/logos/${logo.file}`}
                download
                class="text-xs text-brand-blue border border-brand-blue rounded-md px-3 py-1.5 hover:bg-brand-blue hover:text-white transition-colors"
              >
                Download
              </a>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-8 p-6 bg-gray-50 rounded-xl">
        <h3 class="font-heading font-semibold text-brand-black mb-2">Logo Usage Guidelines</h3>
        <ul class="text-sm text-gray-600 space-y-1.5">
          <li>Use the full-color logo on white or light backgrounds</li>
          <li>Use the white logo on dark or photo backgrounds</li>
          <li>Use the icon/favicon variant for small spaces (social avatars, browser tabs)</li>
          <li>Never stretch, rotate, or alter the logo colors</li>
          <li>Maintain minimum clear space equal to the height of the "A" icon around the logo</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Colors -->
  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl font-heading font-bold text-brand-black mb-2">Colors</h2>
      <p class="text-gray-600 mb-8">Our brand palette. Use these exact values to maintain consistency across all materials.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {colors.map((color) => (
          <div class="bg-white rounded-xl overflow-hidden border border-gray-200">
            <div class="h-24" style={`background-color: ${color.value};`}></div>
            <div class="p-4">
              <h3 class="font-heading font-semibold text-brand-black">{color.name}</h3>
              <div class="flex items-center gap-3 mt-1 mb-2">
                <code class="text-xs bg-gray-100 px-2 py-0.5 rounded font-mono">{color.value}</code>
                <code class="text-xs bg-gray-100 px-2 py-0.5 rounded font-mono">{color.css}</code>
              </div>
              <p class="text-xs text-gray-500">{color.usage}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Typography -->
  <section class="py-16 lg:py-20">
    <div class="container-wide">
      <h2 class="text-3xl font-heading font-bold text-brand-black mb-2">Typography</h2>
      <p class="text-gray-600 mb-8">Two typefaces form the foundation of our brand voice.</p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Headings -->
        <div class="bg-white rounded-xl border border-gray-200 p-8">
          <p class="text-xs text-brand-gold font-heading font-semibold uppercase tracking-wider mb-4">Headings</p>
          <h3 class="text-4xl font-heading font-bold text-brand-black mb-2">Poppins</h3>
          <p class="text-sm text-gray-500 mb-6">Used for all headings, buttons, and UI labels.</p>
          <div class="space-y-3 border-t border-gray-100 pt-6">
            <p class="font-heading font-bold text-3xl text-brand-black">Bold 700 — Headlines</p>
            <p class="font-heading font-semibold text-xl text-brand-black">SemiBold 600 — Subheads</p>
            <p class="font-heading font-medium text-lg text-brand-black">Medium 500 — Labels</p>
            <p class="font-heading font-normal text-base text-brand-black">Regular 400 — Supporting</p>
          </div>
        </div>

        <!-- Body -->
        <div class="bg-white rounded-xl border border-gray-200 p-8">
          <p class="text-xs text-brand-blue font-heading font-semibold uppercase tracking-wider mb-4">Body</p>
          <h3 class="text-4xl font-body font-bold text-brand-black mb-2">Roboto</h3>
          <p class="text-sm text-gray-500 mb-6">Used for body text, paragraphs, and long-form content.</p>
          <div class="space-y-3 border-t border-gray-100 pt-6">
            <p class="font-body font-bold text-lg text-brand-black">Bold 700 — Emphasis</p>
            <p class="font-body font-medium text-base text-brand-black">Medium 500 — Strong body</p>
            <p class="font-body font-normal text-base text-brand-black">Regular 400 — Body text. The quick brown fox jumps over the lazy dog.</p>
            <p class="font-body font-light text-base text-gray-600">Light 300 — Captions and fine print</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Buttons -->
  <section class="py-16 lg:py-20 bg-gray-50">
    <div class="container-wide">
      <h2 class="text-3xl font-heading font-bold text-brand-black mb-2">Buttons</h2>
      <p class="text-gray-600 mb-8">Button styles used across the site and marketing materials.</p>

      <div class="bg-white rounded-xl border border-gray-200 p-8">
        <div class="flex flex-wrap items-center gap-4 mb-6">
          <a href="#" class="btn-primary">Primary Button</a>
          <a href="#" class="btn-secondary">Secondary Button</a>
        </div>
        <div class="text-sm text-gray-500 space-y-1">
          <p><strong>Primary:</strong> Gold background (#ffaa2b), black text, Poppins SemiBold. Used for main CTAs.</p>
          <p><strong>Secondary:</strong> Blue border (#50a7dd), blue text, fills on hover. Used for secondary actions.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Patterns -->
  <section class="py-16 lg:py-20">
    <div class="container-wide">
      <h2 class="text-3xl font-heading font-bold text-brand-black mb-2">Design Patterns</h2>
      <p class="text-gray-600 mb-8">Reusable visual patterns used across the site.</p>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- H2 Accent Treatment -->
        <div class="bg-white rounded-xl border border-gray-200 p-8">
          <p class="text-xs text-brand-gold font-heading font-semibold uppercase tracking-wider mb-4">H2 Accent Text</p>
          <div class="space-y-4 mb-6">
            <h2 class="text-3xl font-heading font-bold text-brand-black">
              <em class="not-italic text-brand-gold italic">Simple.</em> Fast. <em class="not-italic text-brand-blue italic">Effective.</em>
            </h2>
            <h2 class="text-3xl font-heading font-bold text-brand-black">
              <em class="not-italic text-brand-gold italic">Transform</em> Your Practice
            </h2>
            <h2 class="text-3xl font-heading font-bold text-brand-black">
              Unlock Your Firm's <em class="not-italic text-brand-blue italic">Full Potential</em>
            </h2>
          </div>
          <div class="text-sm text-gray-500 space-y-1 border-t border-gray-100 pt-4">
            <p><strong>Usage:</strong> Apply to key H2 headings for visual interest. Use 1–2 accent words per heading.</p>
            <p><strong>Gold accent:</strong> <code class="text-xs bg-gray-100 px-1.5 py-0.5 rounded">&lt;em class="not-italic text-brand-gold italic"&gt;</code></p>
            <p><strong>Blue accent:</strong> <code class="text-xs bg-gray-100 px-1.5 py-0.5 rounded">&lt;em class="not-italic text-brand-blue italic"&gt;</code></p>
          </div>
        </div>

        <!-- Dotted Background -->
        <div class="bg-white rounded-xl border border-gray-200 p-8">
          <p class="text-xs text-brand-blue font-heading font-semibold uppercase tracking-wider mb-4">Dotted Background</p>
          <div class="bg-gray-50 bg-dots rounded-lg p-8 mb-6 min-h-[160px] flex items-center justify-center">
            <div class="bg-white rounded-lg shadow-sm border border-gray-100 p-6 text-center">
              <p class="font-heading font-semibold text-brand-black">Content card on dotted background</p>
            </div>
          </div>
          <div class="text-sm text-gray-500 space-y-1 border-t border-gray-100 pt-4">
            <p><strong>Usage:</strong> Behind service grids and card sections for subtle texture.</p>
            <p><strong>CSS class:</strong> <code class="text-xs bg-gray-100 px-1.5 py-0.5 rounded">bg-dots</code> (pair with <code class="text-xs bg-gray-100 px-1.5 py-0.5 rounded">bg-gray-50</code>)</p>
            <p><strong>Pattern:</strong> 1px gray dots on a 24px grid</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Brand Voice -->
  <section class="py-16 lg:py-20">
    <div class="container-wide">
      <h2 class="text-3xl font-heading font-bold text-brand-black mb-2">Brand Voice</h2>
      <p class="text-gray-600 mb-8">Guidelines for how we communicate across marketing materials.</p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="font-heading font-semibold text-brand-black mb-3 text-lg">We Are</h3>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-brand-gold flex-shrink-0"></span> Professional yet approachable</li>
            <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-brand-gold flex-shrink-0"></span> Confident and direct</li>
            <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-brand-gold flex-shrink-0"></span> Results-oriented</li>
            <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-brand-gold flex-shrink-0"></span> Empowering, not salesy</li>
            <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-brand-gold flex-shrink-0"></span> Consultative — we build custom solutions, not one-size-fits-all</li>
          </ul>
        </div>
        <div class="bg-white rounded-xl border border-gray-200 p-6">
          <h3 class="font-heading font-semibold text-brand-black mb-3 text-lg">We Avoid</h3>
          <ul class="space-y-2 text-gray-600">
            <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-gray-300 flex-shrink-0"></span> Overly corporate or stiff language</li>
            <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-gray-300 flex-shrink-0"></span> Jargon without explanation</li>
            <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-gray-300 flex-shrink-0"></span> Making promises we can't back up</li>
            <li class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-gray-300 flex-shrink-0"></span> Diminishing competitors</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
