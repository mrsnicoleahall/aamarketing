---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
---

<BaseLayout title="Contact Us" description="Get in touch with Attorney Assistant. Schedule a consultation to learn how we can help your firm.">

  <Hero
    title="Contact Us"
    subtitle="Ready to streamline your firm's operations? Let's talk about how Attorney Assistant can help."
  />

  <section class="py-16 lg:py-24">
    <div class="container-wide">
      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-heading font-bold mb-6">Send Us a Message</h2>
          <form class="space-y-6" action="#" method="POST">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="firstName" class="block text-sm font-medium text-gray-700 mb-1">First Name</label>
                <input
                  type="text"
                  id="firstName"
                  name="firstName"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-blue focus:border-transparent outline-none"
                />
              </div>
              <div>
                <label for="lastName" class="block text-sm font-medium text-gray-700 mb-1">Last Name</label>
                <input
                  type="text"
                  id="lastName"
                  name="lastName"
                  required
                  class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-blue focus:border-transparent outline-none"
                />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-blue focus:border-transparent outline-none"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-blue focus:border-transparent outline-none"
              />
            </div>
            <div>
              <label for="firmName" class="block text-sm font-medium text-gray-700 mb-1">Firm Name</label>
              <input
                type="text"
                id="firmName"
                name="firmName"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-blue focus:border-transparent outline-none"
              />
            </div>
            <div>
              <label for="service" class="block text-sm font-medium text-gray-700 mb-1">Service Interest</label>
              <select
                id="service"
                name="service"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-blue focus:border-transparent outline-none"
              >
                <option value="">Select a service...</option>
                <option value="intake-360">Intake 360</option>
                <option value="impact-assistants">Impact Assistants</option>
                <option value="both">Both Services</option>
                <option value="other">Other / Not Sure</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
              <textarea
                id="message"
                name="message"
                rows="4"
                class="w-full px-4 py-3 rounded-lg border border-gray-300 focus:ring-2 focus:ring-brand-blue focus:border-transparent outline-none resize-y"
              ></textarea>
            </div>
            <button type="submit" class="btn-primary w-full sm:w-auto">
              Send Message
            </button>
          </form>
        </div>

        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-heading font-bold mb-6">Get in Touch</h2>
          <div class="space-y-6">
            <div>
              <h3 class="font-heading font-semibold text-lg mb-2">Email</h3>
              <a href="mailto:info@attorneyassistant.com" class="text-brand-blue hover:underline">
                info@attorneyassistant.com
              </a>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-lg mb-2">Phone</h3>
              <a href="tel:+1234567890" class="text-brand-blue hover:underline">
                (123) 456-7890
              </a>
            </div>
            <div>
              <h3 class="font-heading font-semibold text-lg mb-2">Hours</h3>
              <p class="text-gray-600">Our intake services operate 24/7.</p>
              <p class="text-gray-600">Business office hours: Mon–Fri, 9 AM – 6 PM EST</p>
            </div>
          </div>

          <div class="mt-8 p-6 bg-brand-gold/10 rounded-xl">
            <h3 class="font-heading font-semibold text-lg mb-2">Schedule a Consultation</h3>
            <p class="text-gray-700 mb-4">
              Prefer to talk directly? Schedule a free 30-minute consultation with our team.
            </p>
            <a href="#" class="btn-secondary text-sm">Book a Call</a>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
